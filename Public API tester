def test_tavily(
    query: str,
    max_results: int = 5,
    api_key_from_ui: str = "",
) -> Dict[str, Any]:
    if not query.strip():
        return _result(False, error="Please enter a Tavily search query.")

    api_key = api_key_from_ui.strip() or os.getenv("TAVILY_API_KEY", "").strip()
    if not api_key:
        return _result(
            False,
            error=(
                "Tavily API key is missing. Add TAVILY_API_KEY to .env "
                "or enter the key in the application."
            ),
        )

    url = "https://api.tavily.com/search"
    payload = {
        "query": query.strip(),
        "search_depth": "basic",
        "include_answer": True,
        "include_raw_content": False,
        "max_results": max_results,
    }
    headers = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
    }

    start = time.perf_counter()
    try:
        response = requests.post(
            url,
            json=payload,
            headers=headers,
            timeout=DEFAULT_TIMEOUT,
        )
        elapsed = round((time.perf_counter() - start) * 1000)
        data = _safe_json(response)

        if response.ok:
            return _result(
                True,
                response.status_code,
                elapsed,
                data,
                request_url=url,
            )

        message = (
            data.get("detail")
            if isinstance(data, dict)
            else None
        )
        return _result(
            False,
            response.status_code,
            elapsed,
            data,
            (
                f"Tavily request failed: HTTP {response.status_code}. "
                f"{message or 'Check the API key and request parameters.'}"
            ),
            url,
        )
    except requests.RequestException as exc:
        return _result(
            False,
            elapsed_ms=round((time.perf_counter() - start) * 1000),
            error=f"Tavily connection error: {exc}",
            request_url=url,
        )

