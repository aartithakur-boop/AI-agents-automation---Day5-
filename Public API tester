import os
import time
from typing import Any, Dict

import requests


DEFAULT_TIMEOUT = 20


def _result(
    success: bool,
    status_code: int | None = None,
    elapsed_ms: int | None = None,
    data: Any = None,
    error: str | None = None,
    request_url: str | None = None,
) -> Dict[str, Any]:
    return {
        "success": success,
        "status_code": status_code,
        "elapsed_ms": elapsed_ms,
        "data": data,
        "error": error,
        "request_url": request_url,
    }


def _safe_json(response: requests.Response) -> Any:
    try:
        return response.json()
    except ValueError:
        return {"raw_text": response.text[:3000]}


def test_openstreetmap(place: str, limit: int = 5) -> Dict[str, Any]:
    if not place.strip():
        return _result(False, error="Please enter a place or address.")

    url = "https://nominatim.openstreetmap.org/search"
    params = {
        "q": place.strip(),
        "format": "jsonv2",
        "addressdetails": 1,
        "limit": limit,
    }

    # Nominatim requires applications to identify themselves.
    headers = {
        "User-Agent": "PublicAPITesterLearningApp/1.0 "
        "(educational Streamlit application)"
    }

    start = time.perf_counter()
    try:
        response = requests.get(
            url,
            params=params,
            headers=headers,
            timeout=DEFAULT_TIMEOUT,
        )
        elapsed = round((time.perf_counter() - start) * 1000)
        data = _safe_json(response)

        if response.ok:
            return _result(
                True,
                response.status_code,
                elapsed,
                data,
                request_url=response.url,
            )

        return _result(
            False,
            response.status_code,
            elapsed,
            data,
            f"OpenStreetMap request failed: HTTP {response.status_code}.",
            response.url,
        )
    except requests.RequestException as exc:
        return _result(
            False,
            elapsed_ms=round((time.perf_counter() - start) * 1000),
            error=f"OpenStreetMap connection error: {exc}",
            request_url=url,
        )


def test_open_meteo(latitude: float, longitude: float) -> Dict[str, Any]:
    if not -90 <= latitude <= 90:
        return _result(False, error="Latitude must be between -90 and 90.")
    if not -180 <= longitude <= 180:
        return _result(False, error="Longitude must be between -180 and 180.")

    url = "https://api.open-meteo.com/v1/forecast"
    params = {
        "latitude": latitude,
        "longitude": longitude,
        "current": (
            "temperature_2m,relative_humidity_2m,"
            "weather_code,wind_speed_10m"
        ),
        "timezone": "auto",
    }

    start = time.perf_counter()
    try:
        response = requests.get(url, params=params, timeout=DEFAULT_TIMEOUT)
        elapsed = round((time.perf_counter() - start) * 1000)
        data = _safe_json(response)

        if response.ok:
            return _result(
                True,
                response.status_code,
                elapsed,
                data,
                request_url=response.url,
            )

        return _result(
            False,
            response.status_code,
            elapsed,
            data,
            f"Open-Meteo request failed: HTTP {response.status_code}.",
            response.url,
        )
    except requests.RequestException as exc:
        return _result(
            False,
            elapsed_ms=round((time.perf_counter() - start) * 1000),
            error=f"Open-Meteo connection error: {exc}",
            request_url=url,
        )


