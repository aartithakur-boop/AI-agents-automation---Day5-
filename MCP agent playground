from __future__ import annotations

import json
import random
import time
from dataclasses import dataclass, asdict
from datetime import datetime
from typing import Any, Callable, Dict, List


@dataclass
class MCPEvent:
    step: int
    actor: str
    action: str
    detail: str
    payload: Dict[str, Any]
    timestamp: str


LOCAL_TOOLS: Dict[str, Dict[str, Any]] = {
    "read_inventory": {
        "description": "Read inventory details for a product from a local data source.",
        "input_schema": {"product": "string"},
    },
    "calculate_bmi": {
        "description": "Calculate BMI using weight and height.",
        "input_schema": {"weight_kg": "number", "height_cm": "number"},
    },
    "summarize_notes": {
        "description": "Summarize local meeting notes.",
        "input_schema": {"notes": "string"},
    },
}

REMOTE_TOOLS: Dict[str, Dict[str, Any]] = {
    "get_weather": {
        "description": "Retrieve weather information from a remote MCP service.",
        "input_schema": {"city": "string"},
    },
    "lookup_country": {
        "description": "Retrieve country facts from a remote MCP service.",
        "input_schema": {"country": "string"},
    },
    "search_books": {
        "description": "Search books through a remote MCP service.",
        "input_schema": {"topic": "string"},
    },
}

INVENTORY = {
    "laptop": {"stock": 18, "reorder_level": 10, "warehouse": "Bengaluru"},
    "keyboard": {"stock": 7, "reorder_level": 12, "warehouse": "Pune"},
    "monitor": {"stock": 0, "reorder_level": 5, "warehouse": "Hyderabad"},
}

COUNTRY_DATA = {
    "india": {"capital": "New Delhi", "currency": "Indian Rupee", "region": "Asia"},
    "japan": {"capital": "Tokyo", "currency": "Japanese Yen", "region": "Asia"},
    "germany": {"capital": "Berlin", "currency": "Euro", "region": "Europe"},
}

BOOK_DATA = {
    "artificial intelligence": ["Artificial Intelligence: A Modern Approach", "Life 3.0"],
    "python": ["Fluent Python", "Automate the Boring Stuff with Python"],
    "agents": ["Designing Multi-Agent Systems", "AI Agents in Action"],
}

WEATHER_DATA = {
    "bengaluru": {"temperature_c": 26, "condition": "Partly cloudy", "humidity": 68},
    "pune": {"temperature_c": 29, "condition": "Cloudy", "humidity": 61},
    "delhi": {"temperature_c": 34, "condition": "Hazy", "humidity": 55},
}


def _event(step: int, actor: str, action: str, detail: str, payload: Dict[str, Any]) -> MCPEvent:
    return MCPEvent(
        step=step,
        actor=actor,
        action=action,
        detail=detail,
        payload=payload,
        timestamp=datetime.now().strftime("%H:%M:%S"),
    )


def execute_local_tool(tool_name: str, arguments: Dict[str, Any]) -> Dict[str, Any]:
    if tool_name == "read_inventory":
        product = str(arguments.get("product", "")).strip().lower()
        item = INVENTORY.get(product)
        if not item:
            return {"status": "not_found", "message": f"No local inventory record for '{product}'."}
        status = "Reorder" if item["stock"] <= item["reorder_level"] else "Healthy"
        return {"product": product.title(), **item, "status": status}

    if tool_name == "calculate_bmi":
        weight = float(arguments.get("weight_kg", 0))
        height_cm = float(arguments.get("height_cm", 0))
        if weight <= 0 or height_cm <= 0:
            return {"status": "error", "message": "Weight and height must be positive."}
        bmi = weight / ((height_cm / 100) ** 2)
        category = "Underweight" if bmi < 18.5 else "Healthy" if bmi < 25 else "Overweight" if bmi < 30 else "Obesity range"
        return {"bmi": round(bmi, 2), "category": category}

    if tool_name == "summarize_notes":
        notes = str(arguments.get("notes", "")).strip()
        if not notes:
            return {"status": "error", "message": "No notes were supplied."}
        sentences = [s.strip() for s in notes.replace("\n", " ").split(".") if s.strip()]
        return {
            "summary": ". ".join(sentences[:2]) + ("." if sentences else ""),
            "action_items_detected": [s for s in sentences if any(k in s.lower() for k in ["action", "send", "prepare", "complete", "follow up"])],
        }

    return {"status": "error", "message": "Unknown local tool."}


def execute_remote_tool(tool_name: str, arguments: Dict[str, Any], latency_ms: int = 650, fail_rate: int = 0) -> Dict[str, Any]:
    time.sleep(max(latency_ms, 0) / 1000)
    if random.randint(1, 100) <= fail_rate:
        return {"status": "remote_error", "message": "The remote MCP server returned a simulated 503 error."}

    if tool_name == "get_weather":
        city = str(arguments.get("city", "")).strip().lower()
        return {"city": city.title(), **WEATHER_DATA.get(city, {"temperature_c": 28, "condition": "Data simulated", "humidity": 60})}

    if tool_name == "lookup_country":
        country = str(arguments.get("country", "")).strip().lower()
        data = COUNTRY_DATA.get(country)
        return {"country": country.title(), **data} if data else {"status": "not_found", "message": f"No sample record for '{country}'."}

    if tool_name == "search_books":
        topic = str(arguments.get("topic", "")).strip().lower()
        books = BOOK_DATA.get(topic, [f"Introduction to {topic.title()}", f"Practical {topic.title()}"])
        return {"topic": topic.title(), "books": books, "source": "Remote MCP sample catalog"}

    return {"status": "error", "message": "Unknown remote tool."}


def build_trace(mode: str, user_request: str, tool_name: str, arguments: Dict[str, Any], result: Dict[str, Any], include_auth: bool = False) -> List[Dict[str, Any]]:
    is_remote = mode == "remote"
    steps: List[MCPEvent] = [
        _event(1, "User", "Submit request", user_request, {"message": user_request}),
        _event(2, "AI Agent", "Interpret intent", f"The agent decides that '{tool_name}' can satisfy the request.", {"selected_tool": tool_name}),
        _event(3, "MCP Client", "List tools", "The MCP client discovers tools exposed by the server.", {"method": "tools/list", "transport": "HTTPS/SSE" if is_remote else "stdio"}),
    ]
    step = 4
    if is_remote and include_auth:
        steps.append(_event(step, "MCP Client", "Attach authentication", "A bearer token is added before contacting the remote server.", {"authorization": "Bearer ••••••••"}))
        step += 1
    steps.extend([
        _event(step, "MCP Client", "Call tool", f"Arguments are validated against the tool input schema.", {"method": "tools/call", "name": tool_name, "arguments": arguments}),
        _event(step + 1, "MCP Server", "Execute tool", "The server runs the requested capability and returns structured content.", {"result": result}),
        _event(step + 2, "AI Agent", "Generate response", "The agent converts the structured result into a user-friendly answer.", {"grounded_in": "MCP tool result"}),
    ])
    return [asdict(item) for item in steps]


def pretty_json(data: Any) -> str:
    return json.dumps(data, indent=2, ensure_ascii=False)

# MCP Agent Playground

A creative Streamlit learning application that demonstrates how AI agents use the Model Context Protocol (MCP).

## What the app includes

- Local MCP playground using a simulated `stdio` flow
- Remote MCP playground using a simulated HTTP/SSE flow
- Interactive tool discovery and tool execution
- Raw MCP-style request and response payloads
- Authentication, latency, and failure simulation
- Architecture diagrams and execution traces
- Optional OpenAI-generated beginner explanations
- Local vs remote comparison and quiz

