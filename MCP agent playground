def explain_with_openai(trace: list[dict[str, Any]], mode: str, key: str) -> str:
    if not key:
        return "Enter an OpenAI API key in the sidebar to enable AI-generated explanations."
    try:
        from openai import OpenAI
        client = OpenAI(api_key=key)
        response = client.responses.create(
            model="gpt-4.1-mini",
            input=(
                f"Explain this {mode} MCP execution trace to a beginner. Keep it clear, practical, and under 180 words. "
                f"Mention the roles of the agent, MCP client, MCP server, and tool. Trace: {json.dumps(trace)}"
            ),
        )
        return response.output_text
    except Exception as exc:
        return f"OpenAI explanation could not be generated: {exc}"


