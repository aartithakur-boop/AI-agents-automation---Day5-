def _render_trace_item(item: dict[str, Any]) -> None:
    st.markdown(
        f"""
<div class="flow-card">
  <div class="actor">Step {item['step']}: {item['actor']} — {item['action']}</div>
  <div>{item['detail']}</div>
  <div class="tiny">{item['timestamp']}</div>
</div>
""",
        unsafe_allow_html=True,
    )
    if show_protocol:
        st.code(pretty_json(item["payload"]), language="json")


def render_trace(trace: list[dict[str, Any]]) -> None:
    if not animate:
        for item in trace:
            _render_trace_item(item)
        return

    progress = st.progress(0, text="Starting MCP execution...")
    stage = st.empty()
    trace_area = st.empty()
    rendered: list[dict[str, Any]] = []

    for index, item in enumerate(trace, start=1):
        stage.info(f"Running Step {item['step']}: {item['actor']} — {item['action']}")
        rendered.append(item)

        # Rebuild the placeholder with all completed steps. This forces visible,
        # progressive updates instead of displaying the entire trace at once.
        with trace_area.container():
            for completed_item in rendered:
                _render_trace_item(completed_item)

        progress.progress(
            int(index / len(trace) * 100),
            text=f"Completed {index} of {len(trace)} MCP stages",
        )
        time.sleep(0.75)

    stage.success("MCP execution trace completed")
    time.sleep(0.35)
    stage.empty()
    progress.empty()



