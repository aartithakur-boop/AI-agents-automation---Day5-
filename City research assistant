"""
coordinator_agent.py
The Coordinator Agent from the architecture diagram. Uses a Smolagents
`ToolCallingAgent` (no tools of its own — it's a pure reasoning step) to
read the user's free-text question and extract: which two cities, and
what the user's stated priorities/profession/climate/family/budget
preferences are. Answers in structured JSON, which we parse defensively.
"""

from typing import Any, Dict

from smolagents import ToolCallingAgent

import prompts
from utils import extract_json_object

REQUIRED_FIELDS = [
    "city_a", "city_b", "priorities", "profession",
    "climate_preference", "family_requirements", "budget_expectations",
]


def extract_request(model, user_message: str) -> Dict[str, Any]:
    """
    Runs the Coordinator Agent once and returns a structured dict.
    Raises ValueError if the two cities cannot be determined at all.
    """
    agent = ToolCallingAgent(tools=[], model=model, max_steps=3, verbosity_level=0)
    task = prompts.COORDINATOR_SYSTEM_PROMPT.format(user_message=user_message)

    raw_result = agent.run(task)
    parsed = extract_json_object(str(raw_result))

    if not parsed:
        raise ValueError(
            "The Coordinator Agent could not extract structured information from your question. "
            "Try phrasing it like: 'Should I move to Pune or Bengaluru?'"
        )

    for field in REQUIRED_FIELDS:
        parsed.setdefault(field, "" if field != "priorities" else [])

    if not parsed.get("city_a") or not parsed.get("city_b"):
        raise ValueError(
            "Could not identify two cities to compare. Please mention both city names, "
            "e.g. 'Should I move to Pune or Bengaluru?'"
        )

    return parsed

"""
llm_service.py
Wraps creation of the Smolagents OpenAIServerModel — the model wrapper
used by the Coordinator and Comparison agents. The API key is read only
from the environment (via config.py) and is never hardcoded or displayed.
Data-fetching tools (tools.py) never touch this — they are pure Python.
"""

from smolagents import OpenAIServerModel

from config import OPENAI_API_KEY, DEFAULT_MODEL, DEFAULT_TEMPERATURE


def get_model(model_id: str = DEFAULT_MODEL, temperature: float = DEFAULT_TEMPERATURE) -> OpenAIServerModel:
    if not OPENAI_API_KEY:
        raise ValueError(
            "OPENAI_API_KEY is not set. Please add it to your .env file. "
            "See .env.example for the expected format."
        )
    return OpenAIServerModel(
        model_id=model_id,
        api_key=OPENAI_API_KEY,
        client_kwargs={"timeout": 60},
        temperature=temperature,
    )

