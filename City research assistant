"""
research_orchestrator.py
Runs the four specialized research tools — Amenities, Weather, Web
Research, and Book Recommendations — for BOTH cities, in TRUE parallel
using a thread pool. This is the "Multiple specialized agents perform
these research tasks in parallel" step from the architecture.

Each tool call is deterministic Python (see tools.py) — no LLM involved
here. Every result (or per-agent error) is captured into a structured
dict so the UI can show exactly what succeeded/failed, per agent, per
city, without ever inventing missing data.
"""

from concurrent.futures import ThreadPoolExecutor, as_completed
from typing import Any, Callable, Dict, List

from tools import AmenitiesTool, WeatherTool, TavilyResearchTool, OpenLibraryTool
from utils import make_log_entry

AGENT_REGISTRY: Dict[str, Dict[str, Any]] = {
    "amenities": {"display_name": "Amenities Agent", "tool_cls": AmenitiesTool},
    "weather": {"display_name": "Weather Agent", "tool_cls": WeatherTool},
    "web_research": {"display_name": "Web Research Agent", "tool_cls": TavilyResearchTool},
    "books": {"display_name": "Book Recommendation Agent", "tool_cls": OpenLibraryTool},
}


def _run_single(agent_key: str, city: str) -> Dict[str, Any]:
    """Runs one agent's tool for one city, capturing success or failure."""
    display_name = AGENT_REGISTRY[agent_key]["display_name"]
    tool = AGENT_REGISTRY[agent_key]["tool_cls"]()
    try:
        result = tool.forward(city)
        return {
            "agent_key": agent_key, "agent_name": display_name, "city": city,
            "status": "success", "result": result, "error": None,
        }
    except Exception as e:
        return {
            "agent_key": agent_key, "agent_name": display_name, "city": city,
            "status": "error", "result": None, "error": str(e),
        }


def run_research_parallel(
    city_a: str,
    city_b: str,
    progress_callback: Callable[[Dict[str, Any]], None] | None = None,
) -> Dict[str, Any]:
    """
    Runs all 4 agents for both cities concurrently (8 total tasks).
    `progress_callback`, if given, is called once per completed task —
    used by app.py to update the live agent-status UI as results land.

    Returns:
        {
          "results": { agent_key: { city_a: {...}, city_b: {...} } },
          "execution_log": [ ... ],
        }
    """
    tasks = []
    for agent_key in AGENT_REGISTRY:
        for city in (city_a, city_b):
            tasks.append((agent_key, city))

    results: Dict[str, Dict[str, Any]] = {key: {} for key in AGENT_REGISTRY}
    execution_log: List[Dict[str, Any]] = []

    with ThreadPoolExecutor(max_workers=8) as executor:
        future_to_task = {executor.submit(_run_single, key, city): (key, city) for key, city in tasks}
        for future in as_completed(future_to_task):
            agent_key, city = future_to_task[future]
            outcome = future.result()
            results[agent_key][city] = outcome

            log_status = "success" if outcome["status"] == "success" else "error"
            log_entry = make_log_entry(
                outcome["agent_name"],
                f"{'Completed' if log_status == 'success' else 'Failed'} for {city}"
                + (f": {outcome['error']}" if outcome["error"] else ""),
                status=log_status,
            )
            execution_log.append(log_entry)
            if progress_callback:
                progress_callback({"outcome": outcome, "log_entry": log_entry})

    return {"results": results, "execution_log": execution_log}

"""
tools.py
The four data-fetching tools: Amenities (OpenStreetMap/Nominatim),
Weather (Open-Meteo), Web Research (Tavily), and Book Recommendations
(Open Library). Every tool here is pure Python + `requests` — NONE of
them call an LLM. Each `forward()` returns a plain, JSON-safe Python
dict built directly from the API response, so the numbers/counts shown
later are never invented by a model.
"""

from typing import Any, Dict

import requests
from smolagents import Tool

import config


def _get(url: str, params: dict) -> Any:
    """Shared GET helper with a consistent timeout/User-Agent and error handling."""
    response = requests.get(
        url, params=params, headers=config.REQUEST_HEADERS, timeout=config.REQUEST_TIMEOUT_SECONDS
    )
    response.raise_for_status()
    return response.json()


def geocode_city(city: str) -> Dict[str, Any]:
    """Resolves a city name to lat/lon + a bounding box using Nominatim."""
    results = _get(f"{config.NOMINATIM_BASE_URL}/search", {
        "q": city, "format": "json", "limit": 1, "addressdetails": 1,
    })
    if not results:
        raise ValueError(f"Could not geocode city '{city}'. Try a more specific name (e.g. 'Pune, India').")

    place = results[0]
    bbox = place["boundingbox"]  # [south, north, west, east] as strings
    return {
        "display_name": place.get("display_name", city),
        "lat": float(place["lat"]),
        "lon": float(place["lon"]),
        "bounding_box": {
            "south": float(bbox[0]), "north": float(bbox[1]),
            "west": float(bbox[2]), "east": float(bbox[3]),
        },
    }


class AmenitiesTool(Tool):
    name = "amenities_tool"
    description = (
        "Fetches approximate counts of hospitals, schools, railway stations, bus stations, "
        "parks, restaurants, supermarkets, and coworking spaces for a given city, using "
        "OpenStreetMap/Nominatim. Returns a structured dictionary — never invents numbers."
    )
    inputs = {"city": {"type": "string", "description": "City name, e.g. 'Pune' or 'Bengaluru, India'"}}
    output_type = "object"

    def forward(self, city: str) -> dict:
        geo = geocode_city(city)
        bbox = geo["bounding_box"]
        viewbox = f"{bbox['west']},{bbox['north']},{bbox['east']},{bbox['south']}"

        counts = {}
        for key, query_term in config.AMENITY_QUERIES.items():
            try:
                results = _get(f"{config.NOMINATIM_BASE_URL}/search", {
                    "q": query_term, "format": "json", "limit": 50,
                    "viewbox": viewbox, "bounded": 1,
                })
                counts[key] = len(results)
            except Exception:
                counts[key] = None  # honestly report "unknown" rather than guessing

        return {
            "city": city,
            "resolved_location": geo["display_name"],
            "amenity_counts": counts,
            "note": "Counts are approximate — based on OpenStreetMap listings within the city's bounding box.",
        }


class WeatherTool(Tool):
    name = "weather_tool"
    description = (
        "Fetches current weather and a 5-day forecast (temperature, rainfall, humidity, wind) "
        "for a given city, using the Open-Meteo API. Returns a structured dictionary."
    )
    inputs = {"city": {"type": "string", "description": "City name, e.g. 'Pune' or 'Bengaluru'"}}
    output_type = "object"

    def forward(self, city: str) -> dict:
        geo_results = _get(config.OPEN_METEO_GEOCODING_URL, {"name": city, "count": 1})
        matches = geo_results.get("results", [])
        if not matches:
            raise ValueError(f"Could not find weather data for '{city}'.")
        place = matches[0]
        lat, lon = place["latitude"], place["longitude"]

        forecast = _get(config.OPEN_METEO_FORECAST_URL, {
            "latitude": lat, "longitude": lon,
            "current": "temperature_2m,relative_humidity_2m,wind_speed_10m,precipitation",
            "daily": "temperature_2m_max,temperature_2m_min,precipitation_sum",
            "forecast_days": 5, "timezone": "auto",
        })

        return {
            "city": city,
            "resolved_location": f"{place.get('name')}, {place.get('country', '')}".strip(", "),
            "current": forecast.get("current", {}),
            "five_day_forecast": forecast.get("daily", {}),
        }


class TavilyResearchTool(Tool):
    name = "tavily_research_tool"
    description = (
        "Searches the web (via Tavily) for cost of living, job market, rental prices, "
        "traffic/commute, and safety/lifestyle information about a given city. Returns "
        "structured search results (titles, snippets, URLs) per topic — not a written summary."
    )
    inputs = {"city": {"type": "string", "description": "City name, e.g. 'Pune' or 'Bengaluru'"}}
    output_type = "object"

    def forward(self, city: str) -> dict:
        if not config.is_tavily_configured():
            return {"city": city, "topics": {}, "error": "TAVILY_API_KEY is not configured."}

        topics = {}
        for topic_key, query_template in config.TAVILY_RESEARCH_TOPICS.items():
            query = query_template.format(city=city)
            try:
                response = requests.post(
                    config.TAVILY_SEARCH_URL,
                    json={
                        "api_key": config.TAVILY_API_KEY,
                        "query": query,
                        "search_depth": "basic",
                        "max_results": 3,
                    },
                    timeout=config.REQUEST_TIMEOUT_SECONDS,
                )
                response.raise_for_status()
                data = response.json()
                topics[topic_key] = [
                    {"title": r.get("title", ""), "url": r.get("url", ""), "snippet": r.get("content", "")[:400]}
                    for r in data.get("results", [])
                ]
            except Exception as e:
                topics[topic_key] = {"error": str(e)}

        return {"city": city, "topics": topics}


class OpenLibraryTool(Tool):
    name = "open_library_tool"
    description = (
        "Searches Open Library for books related to a city's local history, culture, travel, "
        "and relocation. Returns a structured list of book titles/authors — never invents books."
    )
    inputs = {"city": {"type": "string", "description": "City name, e.g. 'Pune' or 'Bengaluru'"}}
    output_type = "object"

    def forward(self, city: str) -> dict:
        data = _get(config.OPEN_LIBRARY_SEARCH_URL, {"q": city, "limit": 6})
        docs = data.get("docs", [])
        books = [
            {
                "title": d.get("title", "Unknown title"),
                "author": ", ".join(d.get("author_name", [])) or "Unknown author",
                "first_publish_year": d.get("first_publish_year"),
                "url": f"https://openlibrary.org{d.get('key', '')}" if d.get("key") else None,
            }
            for d in docs
        ]
        return {"city": city, "books": books}

"""
utils.py
Shared helpers: execution logging and robust JSON extraction from LLM
agent final answers (agents are instructed to answer in JSON, but we
defensively extract the first valid JSON object rather than assuming
the response is perfectly clean).
"""

import datetime
import json
import re
from typing import Any, Dict, Optional


def now_str() -> str:
    return datetime.datetime.now().strftime("%H:%M:%S")


def make_log_entry(agent_name: str, message: str, status: str = "success") -> Dict[str, Any]:
    return {
        "timestamp": now_str(),
        "agent": agent_name,
        "message": message,
        "status": status,  # "success" | "error" | "info"
    }


def safe_json_dumps(data: Any, indent: int = 2) -> str:
    try:
        return json.dumps(data, indent=indent, default=str)
    except (TypeError, ValueError):
        return str(data)


def extract_json_object(text: str) -> Optional[Dict[str, Any]]:
    """
    Extracts the first valid top-level JSON object found in a block of
    text. Agents are prompted to answer in pure JSON, but LLMs sometimes
    wrap it in markdown fences or add a sentence before/after — this
    strips that defensively instead of crashing the app.
    """
    if not text:
        return None

    # Try direct parse first (the happy path)
    try:
        return json.loads(text)
    except (json.JSONDecodeError, TypeError):
        pass

    # Strip markdown code fences if present
    fenced = re.search(r"```(?:json)?\s*(\{.*?\})\s*```", text, re.DOTALL)
    if fenced:
        try:
            return json.loads(fenced.group(1))
        except json.JSONDecodeError:
            pass

    # Fall back to the widest {...} span in the text
    brace_match = re.search(r"\{.*\}", text, re.DOTALL)
    if brace_match:
        try:
            return json.loads(brace_match.group(0))
        except json.JSONDecodeError:
            pass

    return None
