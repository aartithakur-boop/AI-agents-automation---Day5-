"""
comparison_agent.py
The Comparison Agent from the architecture diagram. Takes the structured
results from all four research agents (never raw model knowledge) and
produces a side-by-side comparison, category scores, pros/cons, and a
final recommendation — explicitly instructed not to invent unavailable
numerical values, and to disclose data limitations honestly.
"""

from typing import Any, Dict

from smolagents import ToolCallingAgent

import prompts
from utils import extract_json_object, safe_json_dumps


def compare_cities(
    model,
    user_question: str,
    coordinator_info: Dict[str, Any],
    research_results: Dict[str, Dict[str, Any]],
) -> Dict[str, Any]:
    """
    Runs the Comparison Agent once and returns a structured comparison dict.
    `research_results` is the {agent_key: {city: outcome}} structure produced
    by research_orchestrator.run_research_parallel().
    """
    city_a = coordinator_info["city_a"]
    city_b = coordinator_info["city_b"]

    def _city_payload(city: str) -> str:
        payload = {}
        for agent_key, per_city in research_results.items():
            outcome = per_city.get(city, {})
            payload[agent_key] = outcome.get("result") if outcome.get("status") == "success" else {
                "error": outcome.get("error", "No data available")
            }
        return safe_json_dumps(payload)

    task = prompts.COMPARISON_SYSTEM_PROMPT.format(
        user_question=user_question,
        priorities=", ".join(coordinator_info.get("priorities", [])) or "not specified",
        city_a=city_a, city_b=city_b,
        city_a_key=city_a, city_b_key=city_b,
        city_a_data=_city_payload(city_a),
        city_b_data=_city_payload(city_b),
    )

    agent = ToolCallingAgent(tools=[], model=model, max_steps=3, verbosity_level=0)
    raw_result = agent.run(task)
    parsed = extract_json_object(str(raw_result))

    if not parsed:
        raise ValueError("The Comparison Agent did not return a valid structured comparison. Please try again.")

    parsed.setdefault("summary", "")
    parsed.setdefault("category_scores", {})
    parsed.setdefault(f"advantages_{city_a}", [])
    parsed.setdefault(f"advantages_{city_b}", [])
    parsed.setdefault("recommendation", "")
    parsed.setdefault("confidence", "Unknown")
    parsed.setdefault("limitations", [])

    return parsed

