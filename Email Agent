"""Reusable helpers for the Interactive Email Agent."""

from __future__ import annotations

import json
import re
from typing import Any


EMAIL_REGEX = re.compile(r"^[^@\s]+@[^@\s]+\.[^@\s]+$")


EMPTY_DRAFT = {
    "recipient": "",
    "cc": "",
    "subject": "",
    "body": "",
}


def normalize_draft(draft: dict[str, Any] | None) -> dict[str, str]:
    """Return a draft with all expected keys and string values."""

    draft = draft or {}
    return {key: str(draft.get(key, "") or "").strip() for key in EMPTY_DRAFT}


def parse_json_object(text: str) -> dict[str, Any]:
    """Parse JSON even if the model accidentally wraps it in text/code fences."""

    cleaned = text.strip()
    cleaned = cleaned.removeprefix("```json").removeprefix("```").removesuffix("```").strip()

    try:
        return json.loads(cleaned)
    except json.JSONDecodeError:
        start = cleaned.find("{")
        end = cleaned.rfind("}")
        if start == -1 or end == -1 or end <= start:
            raise
        return json.loads(cleaned[start : end + 1])


def validate_email_address(value: str) -> bool:
    """Validate a single email address."""

    return bool(EMAIL_REGEX.match(value.strip()))


def validate_email_list(value: str) -> tuple[bool, list[str]]:
    """Validate comma-separated email addresses. Empty values are valid."""

    if not value.strip():
        return True, []
    addresses = [part.strip() for part in value.split(",") if part.strip()]
    invalid = [address for address in addresses if not validate_email_address(address)]
    return len(invalid) == 0, invalid


def missing_required_fields(draft: dict[str, str]) -> list[str]:
    """Return required fields that are still blank."""

    required = ["recipient", "subject", "body"]
    return [field for field in required if not draft.get(field, "").strip()]


def config_status_label(is_configured: bool) -> str:
    """Human-friendly configuration badge text."""

    return "✅ Configured" if is_configured else "❌ Missing"
